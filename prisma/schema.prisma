generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  firebaseUid   String    @unique
  email         String    @unique
  name          String?
  image         String?
  role          String?
  grade         Int?
  leaderboardOptOut Boolean @default(false)
  createdAt     DateTime  @default(now())

  children      ParentChild[] @relation("ParentRelation")
  parents       ParentChild[] @relation("ChildRelation")
  createdAssignments Assignment[] @relation("ParentAssignments")
  receivedAssignments Assignment[] @relation("ChildAssignments")
  answers          Answer[]
  gamification     Gamification?
  earnedBadges     EarnedBadge[]
  practiceSessions PracticeSession[]
  offlineWork      OfflineWork[] @relation("ChildOfflineWork")
  reviewedOfflineWork OfflineWork[] @relation("ParentOfflineWork")
  feedback         Feedback[]
  createdPresets   AssignmentPreset[] @relation("ParentPresets")
  receivedPresets  AssignmentPreset[] @relation("ChildPresets")
  aiUsage          AiUsage[]
  satEnabled       Boolean   @default(false)
  satSessions      SATSession[]
  satAnswers       SATAnswer[]
}

model ParentChild {
  id          String    @id @default(cuid())
  parentId    String
  childId     String?
  inviteToken String    @unique
  childEmail  String
  childName   String
  childGrade  Int       @default(6)
  status              String    @default("pending")
  expiresAt           DateTime
  acceptedAt          DateTime?
  weeklyReportEnabled Boolean   @default(true)
  createdAt           DateTime  @default(now())

  parent User  @relation("ParentRelation", fields: [parentId], references: [id])
  child  User? @relation("ChildRelation", fields: [childId], references: [id])

  @@unique([parentId, childId])
}

model Assignment {
  id            String    @id @default(cuid())
  parentId      String
  childId       String
  grade         Int
  subject       String
  topic         String
  difficulty    String    @default("medium")
  numQuestions  Int
  timeLimitMin  Int?
  reviewMode    String    @default("ai")
  status        String    @default("pending")
  aiFeedback    String?
  parentComment String?
  score         Int?
  pointsAwarded Int?
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  submittedAt   DateTime?
  reviewedAt    DateTime?

  parent    User       @relation("ParentAssignments", fields: [parentId], references: [id])
  child     User       @relation("ChildAssignments", fields: [childId], references: [id])
  questions Question[]
}

model Question {
  id            String   @id @default(cuid())
  assignmentId  String
  questionType  String
  questionText  String
  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  correctAnswer String
  orderIndex    Int

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  answers    Answer[]
}

model Answer {
  id             String    @id @default(cuid())
  questionId     String
  childId        String
  selectedAnswer String?
  isCorrect      Boolean?
  aiExplanation  String?
  aiScore        Int?
  parentComment  String?
  flagged        Boolean   @default(false)
  flagReason     String?
  flagResolvedAt DateTime?
  answeredAt     DateTime  @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  child    User     @relation(fields: [childId], references: [id])

  @@unique([questionId, childId])
}

model PracticeSession {
  id           String    @id @default(cuid())
  childId      String
  grade        Int
  subject      String
  topic        String?
  difficulty   String    @default("medium")
  status       String    @default("in_progress")
  score        Int?
  pointsAwarded Int?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  child     User              @relation(fields: [childId], references: [id])
  questions PracticeQuestion[]
}

model PracticeQuestion {
  id            String  @id @default(cuid())
  sessionId     String
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  orderIndex    Int

  session PracticeSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answers PracticeAnswer[]
}

model PracticeAnswer {
  id             String   @id @default(cuid())
  sessionId      String
  questionId     String
  childId        String
  selectedAnswer String?
  isCorrect      Boolean?
  flagged        Boolean  @default(false)
  answeredAt     DateTime @default(now())

  question PracticeQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, childId])
}

model OfflineWork {
  id             String    @id @default(cuid())
  childId        String
  parentId       String?
  subject        String
  bookReference  String?
  numQuestions   Int
  score          Int
  difficulty     String    @default("medium")
  activityDate   DateTime?
  status         String    @default("pending")
  parentComment  String?
  pointsAwarded  Int?
  createdAt      DateTime  @default(now())
  reviewedAt     DateTime?

  child  User  @relation("ChildOfflineWork", fields: [childId], references: [id])
  parent User? @relation("ParentOfflineWork", fields: [parentId], references: [id])
}

model Gamification {
  id                String  @id @default(cuid())
  childId           String  @unique
  totalPoints       Int     @default(0)
  currentStreak     Int     @default(0)
  longestStreak     Int     @default(0)
  lastCompletedDate String?

  child User @relation(fields: [childId], references: [id])
}

model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  criteria    String

  earnedBy EarnedBadge[]
}

model EarnedBadge {
  id       String   @id @default(cuid())
  childId  String
  badgeId  String
  earnedAt DateTime @default(now())

  child User  @relation(fields: [childId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([childId, badgeId])
}

model Feedback {
  id             String   @id @default(cuid())
  userId         String
  category       String   @default("general")
  message        String
  screenshotUrl  String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AiUsage {
  id               String   @id @default(cuid())
  userId           String
  type             String   // "generation" or "review"
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  assignmentId     String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SATSession {
  id                  String    @id @default(cuid())
  childId             String
  status              String    @default("not_started")
  startedAt           DateTime?
  completedAt         DateTime?
  breakStartedAt      DateTime?
  rwMod2Difficulty    String?
  mathMod2Difficulty  String?
  rwScaledScore       Int?
  mathScaledScore     Int?
  compositeScore      Int?
  pointsAwarded       Int?
  createdAt           DateTime  @default(now())

  child   User         @relation(fields: [childId], references: [id])
  modules SATModule[]
}

model SATModule {
  id           String    @id @default(cuid())
  sessionId    String
  section      String
  moduleNumber Int
  difficulty   String    @default("standard")
  numQuestions Int
  timeLimitMin Int
  status       String    @default("not_started")
  startedAt    DateTime?
  completedAt  DateTime?
  rawScore     Int?

  session   SATSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questions SATQuestion[]
}

model SATQuestion {
  id            String  @id @default(cuid())
  moduleId      String
  questionType  String
  passage       String?
  questionText  String
  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  correctAnswer String
  domain        String
  orderIndex    Int

  module  SATModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  answers SATAnswer[]
}

model SATAnswer {
  id             String   @id @default(cuid())
  questionId     String
  childId        String
  selectedAnswer String?
  isCorrect      Boolean?
  answeredAt     DateTime @default(now())

  question SATQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  child    User        @relation(fields: [childId], references: [id])

  @@unique([questionId, childId])
}

model AssignmentPreset {
  id              String    @id @default(cuid())
  parentId        String
  childId         String
  grade           Int
  subject         String
  topic           String?
  difficulty      String    @default("medium")
  numQuestions    Int       @default(5)
  questionTypes   String    @default("multiple_choice")
  timeLimitMin    Int?
  reviewMode      String    @default("ai")
  daysOfWeek      String    @default("1,2,3,4,5")
  active          Boolean   @default(true)
  lastGeneratedAt DateTime?
  createdAt       DateTime  @default(now())

  parent User @relation("ParentPresets", fields: [parentId], references: [id])
  child  User @relation("ChildPresets", fields: [childId], references: [id])
}
